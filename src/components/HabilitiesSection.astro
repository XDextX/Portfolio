---
import { TECH } from '../data/tech';
import TechGrid from './TechGrid.astro';
import { t } from '@i18n/index';

export interface Props {
	locale?: 'es' | 'en';
}

const { locale = 'es' } = Astro.props;
const titleId = 'skills-title';
const title = t('skills.title');
---

<section class='section' id='skills' aria-labelledby={titleId}>
	<h2 id={titleId}>{title}</h2>
	<TechGrid items={TECH} locale={locale} />
</section>
