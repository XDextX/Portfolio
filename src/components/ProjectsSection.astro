---
import ProjectCard from './ProjectCard.astro';
import type { GitHubRepo } from '../types/github';
import { t } from '@i18n/index';

export interface Props {
	repos: GitHubRepo[];
	title?: string;
	hideTitle?: boolean;
	locale?: 'es' | 'en';
	/** Max repos shown initially. Omit to show all. */
	preview?: number;
}

const {
	repos,
	title = t('projects.title'),
	hideTitle = false,
	locale = 'es',
	preview,
} = Astro.props;

const headingId = 'projects-title';
const labelAttrs = hideTitle
	? { 'aria-label': title }
	: { 'aria-labelledby': headingId };

const topic = import.meta.env.GITHUB_TOPIC;
const topicValue = topic?.trim() || t('projects.topicLabel');

const visible = preview ? repos.slice(0, preview) : repos;
const extra = preview ? repos.slice(preview) : [];

const showMore = t('projects.showMore');
const showLess = t('projects.showLess');
const viewAll = t('projects.viewAll');
---

<section
	class='section'
	id='Projects'
	{...labelAttrs}
	transition:name={`p-${headingId}`}
>
	{
		!hideTitle && (
			<h2
				id={headingId}
				class='section__title'
				transition:name={`p-${headingId}-title`}
			>
				<a href='/proyectos'>{title}</a>
			</h2>
		)
	}

	{
		repos.length === 0 ? (
			<p class='empty'>{t('projects.empty.message', { topic: topicValue })}</p>
		) : (
			<>
				<div class='projects-grid'>
					{visible.map((r) => (
						<ProjectCard repo={r} locale={locale} />
					))}
				</div>

				{extra.length > 0 && (
					<div class='projects-extra' id='projects-extra' aria-hidden='true'>
						<div class='projects-grid'>
							{extra.map((r) => (
								<ProjectCard repo={r} locale={locale} />
							))}
						</div>
					</div>
				)}

				{(extra.length > 0 || preview) && (
					<div class='projects-footer'>
						{extra.length > 0 && (
							<button
								class='btn-toggle'
								id='projects-toggle'
								data-more={showMore}
								data-less={showLess}
								aria-expanded='false'
								aria-controls='projects-extra'
							>
								{showMore}
								<svg
									xmlns='http://www.w3.org/2000/svg'
									width='14'
									height='14'
									viewBox='0 0 24 24'
									fill='none'
									stroke='currentColor'
									stroke-width='2.5'
									stroke-linecap='round'
									stroke-linejoin='round'
									class='chevron'
									aria-hidden='true'
								>
									<polyline points='6 9 12 15 18 9' />
								</svg>
							</button>
						)}

						<a class='btn-all' href='/proyectos'>
							{viewAll}
						</a>
					</div>
				)}
			</>
		)
	}
</section>

<script>
	document.addEventListener('astro:page-load', () => {
		const toggle = document.getElementById(
			'projects-toggle',
		) as HTMLButtonElement | null;
		const extra = document.getElementById('projects-extra');
		if (!toggle || !extra) return;

		toggle.addEventListener('click', () => {
			const expanded = toggle.getAttribute('aria-expanded') === 'true';
			toggle.setAttribute('aria-expanded', String(!expanded));
			extra.setAttribute('aria-hidden', String(expanded));
			extra.classList.toggle('open', !expanded);
			toggle.classList.toggle('open', !expanded);
			toggle.childNodes[0].textContent = !expanded
				? (toggle.dataset.less ?? '') + ' '
				: (toggle.dataset.more ?? '') + ' ';
		});
	});
</script>

<style>
	.projects-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
		gap: 1rem;
	}

	/* Extra repos — collapsed by default */
	.projects-extra {
		display: grid;
		grid-template-rows: 0fr;
		overflow: hidden;
		transition: grid-template-rows 0.4s ease;
	}

	.projects-extra > .projects-grid {
		min-height: 0;
	}

	.projects-extra.open {
		grid-template-rows: 1fr;
	}

	/* Footer */
	.projects-footer {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin-top: 1rem;
		flex-wrap: wrap;
	}

	.btn-toggle {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		padding: 0.45rem 1rem;
		border-radius: var(--radius-md);
		border: 1px solid var(--color-border);
		background: var(--card-background);
		color: var(--text-color);
		font-size: var(--fs-sm);
		font-weight: 600;
		cursor: pointer;
		transition:
			border-color var(--dur) var(--ease),
			color var(--dur) var(--ease);
	}

	.btn-toggle:hover {
		border-color: var(--accent-color);
		color: var(--accent-color);
	}

	.btn-toggle .chevron {
		transition: transform 0.3s ease;
	}

	.btn-toggle.open .chevron {
		transform: rotate(180deg);
	}

	.btn-all {
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
		padding: 0.45rem 1rem;
		border-radius: var(--radius-md);
		border: 1px solid var(--accent-color);
		background: transparent;
		color: var(--accent-color);
		font-size: var(--fs-sm);
		font-weight: 600;
		text-decoration: none;
		transition:
			background var(--dur) var(--ease),
			color var(--dur) var(--ease);
	}

	.btn-all:hover {
		background: var(--accent-color);
		color: #fff;
		text-decoration: none;
	}

	.empty {
		color: var(--neutral-600);
		font-size: var(--fs-sm);
	}

	@media (max-width: 600px) {
		.projects-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
