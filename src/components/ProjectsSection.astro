---
import ProjectCard from './ProjectCard.astro';
import ProjectsFooter from './ProjectsFooter.astro';
import type { GitHubRepo } from '../types/github';
import { t } from '@i18n/index';

export interface Props {
	repos: GitHubRepo[];
	title?: string;
	hideTitle?: boolean;
	locale?: 'es' | 'en';
	/** Max repos shown initially. Omit to show all. */
	preview?: number;
}

const {
	repos,
	title = t('projects.title'),
	hideTitle = false,
	locale = 'es',
	preview,
} = Astro.props;

const headingId = 'projects-title';
const labelAttrs = hideTitle
	? { 'aria-label': title }
	: { 'aria-labelledby': headingId };

const topic = import.meta.env.GITHUB_TOPIC;
const topicValue = topic?.trim() || t('projects.topicLabel');

const visible = preview ? repos.slice(0, preview) : repos;
const extra = preview ? repos.slice(preview) : [];

const showMore = t('projects.showMore');
const showLess = t('projects.showLess');
const viewAll = t('projects.viewAll');
---

<section
	class='section'
	id='Projects'
	{...labelAttrs}
	transition:name={`p-${headingId}`}
>
	{
		!hideTitle && (
			<h2
				id={headingId}
				class='section__title'
				transition:name={`p-${headingId}-title`}
			>
				<a href='/proyectos'>{title}</a>
			</h2>
		)
	}

	{
		repos.length === 0 ? (
			<p class='empty'>{t('projects.empty.message', { topic: topicValue })}</p>
		) : (
			<>
				<div
					class='projects-grid'
					id='projects-grid'
					data-preview={preview ?? repos.length}
				>
					{repos.map((r, i) => (
						<div
							class={`project-item${preview && i >= preview ? ' project-item--hidden' : ''}`}
							aria-hidden={preview && i >= preview ? 'true' : 'false'}
						>
							<ProjectCard repo={r} locale={locale} />
						</div>
					))}
				</div>

				{(extra.length > 0 || preview) && (
					<ProjectsFooter
						showToggle={extra.length > 0}
						showMore={showMore}
						showLess={showLess}
						viewAll={viewAll}
					/>
				)}
			</>
		)
	}
</section>

<script>
	document.addEventListener('astro:page-load', () => {
		const toggle = document.getElementById(
			'projects-toggle',
		) as HTMLButtonElement | null;
		const grid = document.getElementById('projects-grid');
		if (!toggle || !grid) return;

		const hiddenItems = Array.from(
			grid.querySelectorAll<HTMLElement>('.project-item--hidden'),
		);

		toggle.addEventListener('click', () => {
			const expanded = toggle.getAttribute('aria-expanded') === 'true';
			const willExpand = !expanded;

			toggle.setAttribute('aria-expanded', String(willExpand));
			toggle.classList.toggle('open', willExpand);
			toggle.childNodes[0].textContent = willExpand
				? (toggle.dataset.less ?? '') + ' '
				: (toggle.dataset.more ?? '') + ' ';

			hiddenItems.forEach((item, i) => {
				if (willExpand) {
					item.classList.remove('project-item--hidden');
					item.classList.remove('project-item--closing');
					item.style.animationDelay = `${i * 60}ms`;
					item.classList.add('project-item--opening');
					item.removeAttribute('aria-hidden');
				} else {
					item.classList.remove('project-item--opening');
					item.style.animationDelay = `${(hiddenItems.length - 1 - i) * 40}ms`;
					item.classList.add('project-item--closing');
					item.setAttribute('aria-hidden', 'true');
					item.addEventListener(
						'animationend',
						() => {
							item.classList.add('project-item--hidden');
							item.classList.remove('project-item--closing');
						},
						{ once: true },
					);
				}
			});
		});
	});
</script>

<style>
	.projects-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
		gap: 1rem;
	}

	.project-item--hidden {
		display: none;
	}

	@keyframes fadeSlideIn {
		from {
			opacity: 0;
			transform: translateY(12px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@keyframes fadeSlideOut {
		from {
			opacity: 1;
			transform: translateY(0);
		}
		to {
			opacity: 0;
			transform: translateY(12px);
		}
	}

	.project-item--opening {
		animation: fadeSlideIn 0.3s ease both;
	}

	.project-item--closing {
		animation: fadeSlideOut 0.2s ease both;
	}

	.empty {
		color: var(--neutral-600);
		font-size: var(--fs-sm);
	}

	@media (max-width: 600px) {
		.projects-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
