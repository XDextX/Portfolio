---
---

<button id='theme-toggle' class='theme-btn' type='button' aria-label='Switch theme'>
	<!-- Sun icon — visible in dark mode -->
	<svg class='icon icon--sun' xmlns='http://www.w3.org/2000/svg' width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'>
		<circle cx='12' cy='12' r='4'/>
		<path d='M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41'/>
	</svg>
	<!-- Moon icon — visible in light mode -->
	<svg class='icon icon--moon' xmlns='http://www.w3.org/2000/svg' width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'>
		<path d='M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z'/>
	</svg>
</button>

<script is:inline>
	const btn = document.getElementById('theme-toggle');

	function getTheme() {
		return document.documentElement.getAttribute('data-theme') ?? 'light';
	}

	function applyTheme(theme) {
		if (theme === 'dark') {
			document.documentElement.setAttribute('data-theme', 'dark');
		} else {
			document.documentElement.removeAttribute('data-theme');
		}
		localStorage.setItem('theme', theme);
		updateAriaLabel(theme);
	}

	function updateAriaLabel(theme) {
		if (!btn) return;
		btn.setAttribute(
			'aria-label',
			theme === 'dark' ? 'Switch to light theme' : 'Switch to dark theme',
		);
	}

	if (btn) {
		updateAriaLabel(getTheme());
		btn.addEventListener('click', () => {
			applyTheme(getTheme() === 'dark' ? 'light' : 'dark');
		});
	}
</script>

<style>
	.theme-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		background: var(--card-background, #2a2f41);
		color: var(--text-color, #fff);
		border: 1px solid var(--color-border, #3a4056);
		border-radius: 0.4rem;
		padding: 0.3rem 0.5rem;
		cursor: pointer;
		transition: background var(--dur) var(--ease);
	}

	.theme-btn:hover {
		background: var(--neutral-200, #3a3b52);
	}

	/* Light mode (default): show moon to switch to dark */
	.icon--sun {
		display: none;
	}
	.icon--moon {
		display: block;
	}

	/* Dark mode: show sun to switch to light */
	:global([data-theme='dark']) .icon--sun {
		display: block;
	}
	:global([data-theme='dark']) .icon--moon {
		display: none;
	}
</style>
