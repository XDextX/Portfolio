---
import Pill from './Pill.astro';
import { levelLabelMap, levelVariantMap, type Locale, type TechLevel } from '../data/levelLabels';

export interface Props {
	level: TechLevel;
	size?: 'sm' | 'md' | 'xs' | 'lg' | 'xl' | '2xl' | '3xl';
	outline?: boolean;
	locale?: Locale;
}

const { level, size = 'sm', outline = false, locale = 'en' } = Astro.props;

const label = levelLabelMap[locale][level];
const variant = levelVariantMap[level];
---

<Pill text={label} variant={variant} size={size} outline={outline} />
