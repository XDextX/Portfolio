---
import AvatarCircle from './AvatarCircle.astro';
import { ABOUT, JsonLdAbout } from '../data/about';

export interface Props {
	lang?: 'es' | 'en';
	withJsonLd?: boolean;
}

const { lang = 'es', withJsonLd = true } = Astro.props;
const personJsonLd = withJsonLd ? JsonLdAbout : null;

const cvLabel     = lang === 'es' ? 'Descargar CV' : 'Download CV';
const actionsLabel = lang === 'es' ? 'Acciones' : 'Actions';
const locationLabel = lang === 'es' ? 'Ubicación' : 'Location';
---

<section class='section' id='About' aria-labelledby='about-title'>
	{personJsonLd && (
		<script type='application/ld+json' is:inline>{JSON.stringify(personJsonLd)}</script>
	)}

	<div class='about-grid'>
		<!-- Avatar -->
		<div class='about-avatar'>
			<AvatarCircle
				src={ABOUT.avatar}
				alt={ABOUT.name}
				size='100%'
				border
				ringWidth={3}
			/>
		</div>

		<!-- Content -->
		<div class='about-content'>
			<div class='about-meta'>
				<h1 id='about-title' class='about-name'>{ABOUT.name}</h1>
				<div class='about-sub'>
					<span class='about-job'>{ABOUT.title}</span>
					<span class='about-sep' aria-hidden='true'>·</span>
					<span class='about-location' aria-label={locationLabel}>
						<svg xmlns='http://www.w3.org/2000/svg' width='13' height='13' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'><path d='M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z'/><circle cx='12' cy='10' r='3'/></svg>
						{ABOUT.location}
					</span>
				</div>
			</div>

			<p class='about-bio'>{ABOUT.bio[lang]}</p>

			<nav class='about-actions' aria-label={actionsLabel}>
				<a
					class='btn-cv'
					href={ABOUT.resumeUrl}
					download
					rel='noopener'
				>
					<svg xmlns='http://www.w3.org/2000/svg' width='15' height='15' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'><path d='M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4'/><polyline points='7 10 12 15 17 10'/><line x1='12' y1='15' x2='12' y2='3'/></svg>
					{cvLabel}
				</a>

				{ABOUT.socials.map((s) => (
					<a
						class='btn-social'
						href={s.href}
						target='_blank'
						rel='noopener noreferrer me'
						aria-label={s.label}
						title={s.label}
					>
						{s.label}
					</a>
				))}
			</nav>
		</div>
	</div>
</section>

<style>
	.about-grid {
		display: grid;
		grid-template-columns: 180px 1fr;
		align-items: center;
		gap: 2rem;
	}

	/* Avatar column */
	.about-avatar {
		width: 180px;
		height: 180px;
	}

	/* Content column */
	.about-content {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.about-meta {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}

	.about-name {
		font-size: var(--fs-3xl, 2rem);
		font-weight: 800;
		color: var(--accent-color);
		margin: 0;
		line-height: 1.2;
	}

	.about-sub {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		flex-wrap: wrap;
	}

	.about-job {
		font-size: var(--fs-sm);
		font-weight: 700;
		color: var(--text-color);
	}

	.about-sep {
		color: var(--neutral-600);
		opacity: 0.5;
	}

	.about-location {
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
		font-size: var(--fs-sm);
		color: var(--neutral-600);
	}

	.about-bio {
		font-size: var(--fs-base);
		color: var(--neutral-600);
		line-height: 1.7;
		margin: 0;
	}

	/* Actions */
	.about-actions {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		flex-wrap: wrap;
	}

	.btn-cv {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.5rem 1.1rem;
		border-radius: var(--radius-md);
		background: var(--accent-color);
		color: #fff;
		font-size: var(--fs-sm);
		font-weight: 700;
		text-decoration: none;
		border: 1px solid transparent;
		transition:
			opacity var(--dur) var(--ease),
			transform var(--dur) var(--ease);
	}

	.btn-cv:hover {
		opacity: 0.88;
		transform: translateY(-1px);
		text-decoration: none;
		color: #fff;
	}

	.btn-social {
		display: inline-flex;
		align-items: center;
		padding: 0.5rem 0.9rem;
		border-radius: var(--radius-md);
		border: 1px solid var(--color-border);
		background: var(--card-background);
		color: var(--text-color);
		font-size: var(--fs-sm);
		font-weight: 600;
		text-decoration: none;
		transition:
			border-color var(--dur) var(--ease),
			color var(--dur) var(--ease),
			transform var(--dur) var(--ease);
	}

	.btn-social:hover {
		border-color: var(--accent-color);
		color: var(--accent-color);
		transform: translateY(-1px);
		text-decoration: none;
	}

	/* Responsive */
	@media (max-width: 720px) {
		.about-grid {
			grid-template-columns: 1fr;
			text-align: left;
		}

		.about-avatar {
			width: 120px;
			height: 120px;
		}
	}
</style>
