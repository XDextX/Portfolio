---
export interface Props {
	role: string;
	company: string;
	period: string;
	location?: string;
	bullets: string[];
}

const { role, company, period, location, bullets } = Astro.props as Props;
---

<article class='shadow p-4' aria-labelledby={`${company}-title`}>
	<h3 id={`${company}-title`} class='exp-title'>
		<span class='role'>{role}</span>
		<span class='sep'> · </span>
		<span class='company'>{company}</span>
		<span class='period'>({period})</span>
	</h3>

	{location && <p class='location'>{location}</p>}

	<ul class='bullets'>
		{bullets.map((item) => <li>{item}</li>)}
	</ul>
</article>

<style>
	.shadow {
		border-bottom: 3px solid rgb(0, 0, 0, 0.2);
		border-right: 3px solid rgb(0, 0, 0, 0.2);
		box-shadow: 0 6px 16px rgba(0, 0, 0, 0.08);
	}
	.exp-title {
		font-weight: 800;
		margin: 0 0 0.25rem 0;
		line-height: 1.3;
	}
	.role {
		color: var(--accent-color);
	}
	.period {
		font-weight: 700;
		margin-left: 0.4rem;
	}
	.location {
		color: var(--accent-color-dark);
		margin: 0.1rem 0 0.6rem 0;
		font-size: 0.95rem;
	}
	.bullets {
		margin: 0;
		padding-left: 1.2rem;
		display: grid;
		gap: 0.4rem;
	}
	.bullets li {
		color: var(--text-color);
	}
	.sep {
		font-weight: 700;
	}
</style>
