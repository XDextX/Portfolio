---
export interface Props {
	text: string;
}
const { text } = Astro.props;
---

<span class='chip'>{text}</span>

<style>
	.chip {
		display: inline-block;
		font-size: var(--fs-xs);
		font-weight: 600;
		padding: 0.2rem 0.55rem;
		border-radius: 999px;
		border: 1px solid var(--color-border);
		background: var(--card-background);
		color: var(--neutral-600);
		white-space: nowrap;
		user-select: none;
	}
</style>
