---
export interface Props {
	text: string;
}
const { text } = Astro.props;
---

<span class='chip'>{text}</span>

<style>
	.chip {
		display: inline-block;
		font-size: 0.72rem;
		font-weight: 600;
		padding: 0.22rem 0.5rem;
		border-radius: 999px;
		white-space: nowrap;
		user-select: none;
	}
</style>
