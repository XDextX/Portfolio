---
import ExperienceCard from './ExperienceCard.astro';
import { EXPERIENCES } from '../data/experience';
import { t } from '@i18n/index';
import Section from './Section.astro';

export interface Props {
	locale?: 'es' | 'en';
}

const { locale = 'es' } = Astro.props as Props;
const titleId = 'work-exp-title';
const title = t('experience.title');
---

<Section class='section' aria-labelledby={titleId}>
	<h2 id={titleId}>{title}</h2>

	<div class='grid grid-2 gap-2 px-4 mt-4'>
		{
			EXPERIENCES.map((e) => (
				<ExperienceCard
					role={e.role[locale]}
					company={e.company}
					period={e.period[locale]}
					location={e.location?.[locale]}
					bullets={e.bullets[locale]}
				/>
			))
		}
	</div>
</Section>

<style>
	@media (max-width: 980px) {
		.grid {
			grid-template-columns: 1fr;
		}
	}
</style>
